# Copy to .env and adjust for your machine. Not hot-reloaded — restart the app after
# changing any of these.

# ALSA capture device for the USB turntable interface. Confirm with `arecord -l`;
# on this dev machine it showed up as card 4 "CODEC [USB Audio CODEC]".
ALSA_DEVICE=plughw:CARD=CODEC,DEV=0
SAMPLE_RATE=44100
CHANNELS=2
SAMPLE_WIDTH=2

# OwnTone's pipe library input — must be a FIFO (mkfifo) ending in `.pipe`, inside a
# directory OwnTone's `library.directories` config includes.
FIFO_PATH=/var/lib/owntone/library/vinyl.pipe

# OwnTone JSON API base URL.
OWNTONE_BASE_URL=http://localhost:3689

# How OwnTone's library search finds our pipe track (see docs/owntone-setup.md).
OWNTONE_PIPE_TRACK_QUERY=vinyl

# Recognition cadence.
RECOGNIZE_POLL_INTERVAL_SECONDS=25
RECOGNIZE_SNAPSHOT_SECONDS=10
