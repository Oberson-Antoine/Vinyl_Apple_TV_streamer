# Local dev override. TESTING WITH THE FIFINE MIC instead of the UFO202 — no line-in
# cable/turntable access right now, so using the Fifine as a stand-in analog source to
# exercise the real capture pipeline. Switch back to plughw:CARD=CODEC,DEV=0 once the
# UFO202 is reachable again.
ALSA_DEVICE=plughw:CARD=Microphone,DEV=0
SAMPLE_RATE=44100
CHANNELS=2
SAMPLE_WIDTH=2

FIFO_PATH=/var/lib/owntone/library/vinyl.pipe
OWNTONE_BASE_URL=http://localhost:3689
OWNTONE_PIPE_TRACK_QUERY=vinyl

RECOGNIZE_POLL_INTERVAL_SECONDS=25
RECOGNIZE_SNAPSHOT_SECONDS=10
