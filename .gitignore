# Virtual environments — machine/architecture-specific (compiled wheels won't
# even run across x86_64 <-> ARM), always regenerate from requirements*.txt.
.venv/
venv/

# Python bytecode/caches
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Local machine-specific config — copy from .env.example instead of committing.
.env

.DS_Store
